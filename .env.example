# =============================================================================
# TestPilot AI — Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub ---
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# --- Langfuse (LLM observability) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- PostgreSQL ---
# Local development (docker-compose postgres service)
DATABASE_URL=postgresql://testpilot:testpilot@localhost:5432/testpilot

# AWS RDS (production)
# DATABASE_URL=postgresql://testpilot:<password>@<rds-endpoint>.us-east-2.rds.amazonaws.com:5432/testpilot

# --- AWS (LocalStack for local dev) ---
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-2
AWS_ENDPOINT_URL=http://localhost:4566

# AWS SQS
SQS_QUEUE_NAME=testpilot-jobs
SQS_QUEUE_URL=http://localhost:4566/000000000000/testpilot-jobs

# AWS S3
S3_BUCKET_NAME=testpilot-artifacts

# --- App ---
APP_ENV=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
